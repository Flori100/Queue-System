{
  "name": "qlist-design",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-tokens": "cp src/tokens.css public/tokens.css",
    "sync-chart": "cp node_modules/chart.js/dist/chart.umd.js public/chart.umd.js",
    "sync-static-js": "cp src/qlist-auth-standalone.js public/qlist-auth-standalone.js && cp src/business-dashboard.js public/business-dashboard.js",
    "predev": "npm run sync-tokens && npm run sync-static-js && npm run sync-chart",
    "prebuild": "npm run sync-tokens && npm run sync-static-js && npm run sync-chart",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "chart.js": "^4.4.1",
    "framer-motion": "^11.18.2",
    "gsap": "^3.15.0",
    "leaflet": "^1.9.4",
    "ogl": "^1.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "imagetracerjs": "^1.2.6",
    "jpeg-js": "^0.4.4",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.11"
  }
}
